{
  "permissions": {
    "allow": [
      "mcp__playwright",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "WebFetch(domain:anthropic.skilljar.com)",
      "Bash(npm list:*)",
      "Bash(npm install:*)",
      "Skill(claude-api)",
      "Skill(claude-api:*)",
      "Bash(command -v omm)",
      "Bash(omm config:*)",
      "Bash(omm write:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node ./hooks/read_hook.js"
          }
        ]
      }
    ]
  }
}
